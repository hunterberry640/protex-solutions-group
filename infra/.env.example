# ── Account ───────────────────────────────────────────────────────────────────
# 12-digit AWS account ID (find it in the AWS console top-right corner)
AWS_ACCOUNT_ID=

# AWS region for S3 and other regional resources (CloudFront is always global)
AWS_REGION=us-east-1

# ── Credentials ───────────────────────────────────────────────────────────────
# IAM user credentials with permissions for S3, CloudFront, Route 53, ACM
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Site ──────────────────────────────────────────────────────────────────────
# Root domain name — no protocol, no www (e.g. acmecleaning.com)
DOMAIN_NAME=
